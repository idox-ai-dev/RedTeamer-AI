# ── Evaluator Provider ────────────────────────────────────────────────────────
# Choose one: anthropic | openai | azure_openai | openai_compatible
EVALUATOR_PROVIDER=azure_openai

# ── Anthropic (provider=anthropic) ───────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenAI / ChatGPT (provider=openai) ───────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1   # override for self-hosted

# ── OpenAI-compatible self-hosted (provider=openai_compatible) ────────────────
# e.g. Ollama: http://localhost:11434/v1  |  vLLM: http://localhost:8000/v1
# OPENAI_COMPATIBLE_BASE_URL=http://localhost:11434/v1
# OPENAI_COMPATIBLE_API_KEY=ollama
# OPENAI_COMPATIBLE_MODEL=llama3

# ── Azure OpenAI (provider=azure_openai) ─────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-key
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Database
DATABASE_URL=sqlite:///./redteam.db

# Server
API_HOST=0.0.0.0
API_PORT=8000

# Max concurrent attacks per job (hard ceiling; request cannot exceed this value)
DEFAULT_MAX_CONCURRENCY=3

# Admin registration token (keep this secret)
ADMIN_TOKEN=change-me-to-secret-admin-token

# Optional: shared API key for local PoC (Web UI login + bypass client). Leave empty in production.
BYPASS_API_KEY=
