# ── OpenClaw ──────────────────────────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-strong-random-token
OPENCLAW_GATEWAY_PORT=8789
OPENCLAW_OBSERVER_PORT=8790
OPENCLAW_LOG_LEVEL=info
TZ=Asia/Taipei

# ── Red Team Auth ─────────────────────────────────────────────────
# Bypass key: skips client registration (POC mode).
# Use the same value in AGENT_API_KEY for the attack-agent.
# BYPASS_API_KEY: local PoC / demo convenience — leave unset or empty in production to disable.
BYPASS_API_KEY=change-me-to-a-strong-random-secret
# Admin token for client registration (set to something strong in production)
ADMIN_TOKEN=change-me-to-a-strong-random-secret

# ── Attack Agent ──────────────────────────────────────────────────
CLOUD_API_URL=http://nux-api-server:8000
AGENT_HOST_URL=http://nux-attack-agent:9000
AGENT_PORT=9000
OPENCLAW_TIMEOUT=300

# ── API Server ────────────────────────────────────────────────────
API_PORT=8000

# LiteLLM proxy (used by openclaw agent inside Docker)
# host.docker.internal points to the host machine (Mac/Windows Docker Desktop)
LITELLM_BASE_URL=http://host.docker.internal:4000/v1
LITELLM_API_KEY=your-litellm-api-key
LITELLM_MODEL_ID=gpt-5-mini
LITELLM_MODEL_NAME=GPT-5 Mini (Azure)

# Azure OpenAI (for LLM scenario generation + evaluation)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview
