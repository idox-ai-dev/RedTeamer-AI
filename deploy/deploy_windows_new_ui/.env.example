# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite:///./redteam.db
BYPASS_API_KEY=change-me-to-your-api-key
ADMIN_TOKEN=change-me-to-admin-token
# Max concurrent attacks per job (hard ceiling — request cannot exceed this value)
DEFAULT_MAX_CONCURRENCY=3

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ── Attack Agent ──────────────────────────────────────────────────────────────
AGENT_HOST=0.0.0.0
AGENT_PORT=9000
AGENT_HOST_URL=http://localhost:9000
CLOUD_API_URL=http://localhost:8000
AGENT_API_KEY=change-me-to-your-api-key
CLIENT_NAME=default
OBSERVER_URL=http://127.0.0.1:18790
OPENCLAW_TIMEOUT=120

# ── Windows only ──────────────────────────────────────────────────────────────
# On Windows, set the full path to openclaw.cmd (replace <YourUsername>):
# OPENCLAW_BIN=C:\Users\<YourUsername>\AppData\Roaming\npm\openclaw.cmd
